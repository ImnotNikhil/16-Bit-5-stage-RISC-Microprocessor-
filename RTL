// ===================================================================
// CORRECT PIPELINED DUAL-PORT DATA MEMORY
// ===================================================================
module data_memory (
    input clk, reset,
    input mem_read, mem_write,
    input [7:0]  addr,
    input [15:0] write_data,
    output wire [15:0] read_data
);
reg [15:0] memory [0:255];
integer i;

always @(posedge clk or posedge reset) begin
    if (reset) begin
        for (i=0; i<256; i=i+1) memory[i] <= 16'd0;
    end
    else if (mem_write) begin
        memory[addr] <= write_data;
    end
end

// Combinational read with same-address write-through forwarding
wire write_collision = mem_write; // simplified: always forward on concurrent write
                                  // Full version: mem_write (addr match implicit
                                  // since only one addr port)

assign read_data = !mem_read                    ? 16'd0      :
                   (mem_write)                  ? write_data : // write-through
                   memory[addr];

endmodule

// ==================
// MEM/WB Register
// ==================
module mem_wb_reg (
    input clk, reset,
    input [15:0] mem_data_in, alu_result_in,
    input [2:0]  rd_in,
    input alu_stall,    // ← use this instead of stall for hold condition
    input        reg_write_in, mem_to_reg_in, halt_in,
    input mul_done_in, div_done_in,
    output reg        halt_out,
    output reg [15:0] mem_data_out, alu_result_out,
    output reg [2:0]  rd_out,
    output reg        reg_write_out, mem_to_reg_out
);
// Add stall and done ports to mem_wb_reg:
// input stall, mul_done_in, div_done_in  (add to port list)

always @(posedge clk or posedge reset) begin
    if (reset) begin
        mem_data_out<=0; alu_result_out<=0; rd_out<=0;
        halt_out<=0; reg_write_out<=0; mem_to_reg_out<=0;
    end
    else if (mul_done_in || div_done_in || !alu_stall) begin
        mem_data_out   <= mem_data_in;
        alu_result_out <= alu_result_in;
        rd_out         <= rd_in;
        halt_out       <= halt_in;
        reg_write_out  <= reg_write_in;
        mem_to_reg_out <= mem_to_reg_in;
    end
    // else: hold
end

`ifdef SIMULATION
always @(posedge clk) begin
    $display("MEMWBDBG: alu_in=%0d alu_out=%0d rd_in=%0d rd_out=%0d regwrite_in=%b regwrite_out=%b",
        alu_result_in, alu_result_out, rd_in, rd_out, reg_write_in, reg_write_out);
end
`endif

endmodule

