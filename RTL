//============================================================
// STAGE 1 : IF
//============================================================
wire [7:0]  pc;
wire [15:0] instr;
wire        stall, flush;
wire        branch_taken;
wire [7:0]  branch_addr;
wire        halt_wb;
wire start_div_capture_pulse;  // NEW

program_counter PC (
    .clk(clk),
    .reset(reset),
    .stall(stall),
    .halt(halt_wb),
    .branch_taken(branch_taken),
    .branch_addr(branch_addr),
    .pc(pc)
);
instruction_memory IMEM (.addr(pc),.instr(instr));
flush_unit FLUSH (.branch_taken(branch_taken),.flush(flush));

wire [7:0]  pc_id;
wire [15:0] instr_id;
if_id_reg IF_ID (
    .clk(clk),.reset(reset),.stall(stall),.flush(flush),
    .pc_in(pc),.instr_in(instr),.pc_out(pc_id),.instr_out(instr_id)
);

//============================================================
// STAGE 2 : ID
//============================================================
wire [1:0] group;
wire [2:0] opcode, rd, rs1, rs2;
wire [4:0] imm;

instruction_decoder DEC (
    .instr(instr_id),.group(group),.opcode(opcode),
    .rd(rd),.rs1(rs1),.rs2(rs2),.imm(imm)
);

wire        alu_src, reg_write, mem_read, mem_write, mem_to_reg;
wire        jump, halt, flag_write;
wire [2:0]  alu_op;
wire        is_push, is_pop, is_peak;

control_unit CTRL (
    .group(group),.opcode(opcode),
    .is_push(is_push),.is_pop(is_pop),.is_peak(is_peak),
    .alu_src(alu_src),.reg_write(reg_write),.mem_read(mem_read),
    .mem_write(mem_write),.mem_to_reg(mem_to_reg),
    .jump(jump),.halt(halt),.alu_op(alu_op),.flag_write(flag_write)
);

wire [15:0] rs1_data, rs2_data;
wire [15:0] writeback_data;
wire        reg_write_wb;
wire [2:0]  rd_wb;
wire        alu_stall;

register_file RF (
    .clk(clk),.reset(reset),.reg_write(reg_write_wb),
    .rs1(rs1),.rs2(rs2),.rd(rd_wb),.write_data(writeback_data),
    .read_data1(rs1_data),.read_data2(rs2_data)
);

wire [15:0] imm_ext;
immediate_generator IMM (.imm_in(imm),.imm_out(imm_ext));

wire hazard_stall;
wire [2:0] rd_ex;
wire       mem_read_ex;
// rs1 is read by almost everything except LOADI (Group 10, Opcode 011)
wire rs1_read_id =
    ~(group == 2'b10 && opcode[2:0] == 3'b011); 

// rs2 is only read if we are NOT using an immediate value
wire rs2_read_id = ~alu_src;
hazard_unit HAZARD_inst (
    .rs1_id(rs1),              // [FIX] Map to actual rs1 from instruction decoder
    .rs2_id(rs2),              // [FIX] Map to actual rs2 from instruction decoder
    .rs1_read_id(rs1_read_id), 
    .rs2_read_id(rs2_read_id), 
    .rd_ex(rd_ex),
    .mem_read_ex(mem_read_ex),
    .hazard_stall(hazard_stall)
);

//------------------------------------------------------------
// ID/EX REGISTER
//------------------------------------------------------------
wire [7:0]  pc_ex;
wire [15:0] rs1_ex, rs2_ex, imm_ex;
wire [2:0]  rs1_addr_ex, rs2_addr_ex, opcode_ex;
wire [2:0]  alu_op_ex;
wire        alu_src_ex, reg_write_ex, mem_write_ex, mem_to_reg_ex;
wire        jump_ex, flag_write_ex;
wire        halt_ex;
wire [1:0]  group_ex;
wire        is_push_ex, is_pop_ex, is_peak_ex;


// ===================================================================
// UPDATE THIS INSTANTIATION INSIDE cpu_top
// Gates incoming ID control signals during a hazard condition
// ===================================================================
id_ex_reg ID_EX (
    .clk(clk),.reset(reset),.hazard_stall(hazard_stall),
    .alu_stall(alu_stall),.flush(flush),
    .pc_in(pc_id),.rs1_in(rs1_data),.rs2_in(rs2_data),
    .imm_in(imm_ext),.rd_in(rd),.group_in(group),.halt_in(halt),
    .halt_out(halt_ex),.group_out(group_ex),
    .alu_op_in(alu_op),.alu_src_in(alu_src),
    .reg_write_in(reg_write),.mem_read_in(mem_read),
    .mem_write_in(mem_write),.mem_to_reg_in(mem_to_reg),
    .jump_in(jump),.flag_write_in(flag_write),
    .rs1_addr_in(rs1),.rs2_addr_in(rs2),.opcode_in(opcode),
    .opcode_out(opcode_ex),.rs1_addr_out(rs1_addr_ex),.rs2_addr_out(rs2_addr_ex),
    .pc_out(pc_ex),.rs1_out(rs1_ex),.rs2_out(rs2_ex),
    .imm_out(imm_ex),.rd_out(rd_ex),
    .alu_op_out(alu_op_ex),.alu_src_out(alu_src_ex),
    .reg_write_out(reg_write_ex),.mem_read_out(mem_read_ex),
    .mem_write_out(mem_write_ex),.mem_to_reg_out(mem_to_reg_ex),
    .jump_out(jump_ex),.flag_write_out(flag_write_ex),
    .is_push_in(is_push),.is_pop_in(is_pop),.is_peak_in(is_peak),
    .is_push_out(is_push_ex),.is_pop_out(is_pop_ex),.is_peak_out(is_peak_ex)
);
//============================================================
// STAGE 3 : EX
//============================================================
wire [2:0]  rd_mem;
wire [15:0] result_mem;
wire        reg_write_mem;

wire [1:0] forwardA, forwardB;
forwarding_unit FWD (
    .rs1_ex(rs1_addr_ex),.rs2_ex(rs2_addr_ex),
    .rd_mem(rd_mem),.rd_wb(rd_wb),
    .reg_write_mem(reg_write_mem),.reg_write_wb(reg_write_wb),
    .forwardA(forwardA),.forwardB(forwardB)
);

wire [15:0] opA, opB_raw, opB;

forward_mux FMUX_A (
    .reg_data(rs1_ex),.ex_mem_data(result_mem),
    .mem_wb_data(writeback_data),.forward_sel(forwardA),.out(opA)
);
forward_mux FMUX_B (
    .reg_data(rs2_ex),.ex_mem_data(result_mem),
    .mem_wb_data(writeback_data),.forward_sel(forwardB),.out(opB_raw)
);

operand_mux OPMUX (
    .reg_data(opB_raw),.imm_data(imm_ex),
    .alu_src(alu_src_ex),.operand_out(opB)
);

wire is_move  = (group_ex==2'b10) && (alu_op_ex==3'b010);
wire is_loadi = (group_ex==2'b10) && (alu_op_ex==3'b011);
wire is_clear = (group_ex==2'b10) && (alu_op_ex==3'b111);

wire [15:0] opA_final = is_loadi ? 16'd0 : opA;

wire [15:0] alu_result;
wire [3:0]  flags;
wire         mul_done_ex, div_done_ex;

pipelined_alu ALU (
    .clk(clk),.rst(reset),
    .A(opA_final),.B(opB),
    .opcode({group_ex, alu_op_ex}),
    .flags(flags),.result(alu_result),
    .stall(alu_stall),
    .mul_done_out(mul_done_ex),.div_done_out(div_done_ex),
    .start_div_out(start_div_capture_pulse)
);

always @(posedge clk) begin
    if(reg_write_wb)
    $display(
    "FINALWB: rd=%0d data=%0d",
    rd_wb,
    writeback_data
    );
end

// ==================
// FLAG PIPELINE (Direct wire into register)
// ==================
wire [3:0] flags_out;
flag_register FLAGS (
    .clk(clk),
    .reset(reset),
    .flag_write((flag_write_ex & ~alu_stall) | mul_done_ex | div_done_ex), // Only write if not stalled
    .flags_in(flags),                        // Wire directly from combinational ALU
    .flags_out(flags_out)
);

// ==================
// BRANCH PIPELINE
// [F2] pc_branch_d and imm_branch_d are held when stall is active
// ==================
reg [4:0] opcode_branch_d;
reg [7:0] pc_branch_d, imm_branch_d;
reg       jump_branch_d;
always @(posedge clk or posedge reset) begin
    if (reset) begin
        opcode_branch_d <= 5'b0; pc_branch_d <= 8'b0;
        imm_branch_d    <= 8'b0; jump_branch_d <= 1'b0;
    end
    // [F2] Hold branch pipeline on any stall so target is not computed from stale PC
    else if (!stall) begin
        opcode_branch_d <= {group_ex, alu_op_ex};
        pc_branch_d     <= pc_ex;
        imm_branch_d    <= imm_ex[7:0];
        jump_branch_d   <= jump_ex;
    end
end

branch_unit BRANCH (
    .jump(jump_branch_d),.opcode(opcode_branch_d),
    .flags_out(flags_out),.pc_ex(pc_branch_d),
    .imm_ex(imm_branch_d),.branch_taken(branch_taken),
    .branch_addr(branch_addr)
);

stall_unit STALL (
    .alu_stall(alu_stall),.hazard_stall(hazard_stall),.stall(stall)
);

// ==================
// MUL/DIV destination register tracking
// [F5] Captured only on start_mul/start_div, not on every matching cycle
// ==================
reg alu_stall_d;

always @(posedge clk or posedge reset) begin
    if(reset)
        alu_stall_d <= 0;
    else
        alu_stall_d <= alu_stall;
end

// stall-rising-edge which is when MUL starts. Add explicit group check:
wire mul_rising_edge = alu_stall && !alu_stall_d;
wire mul_start_capture = mul_rising_edge
    && (group_ex == 2'b00)
    && (alu_op_ex == 3'b010)
    && reg_write_ex;   // only save if this instruction actually writes back

// div_start_capture: use start_div pulse directly.
// The rising-edge-of-alu_stall approach fails when alu_stall is already
// high from a preceding MUL (no falling edge between MUL and DIV).
// start_div is a clean 1-cycle pulse that fires exactly when DIV begins,
// regardless of prior stall history.
wire div_start_capture = start_div_capture_pulse;

reg [2:0] mul_rd_saved;
reg [2:0] div_rd_saved;

reg mul_regwrite_saved;
reg div_regwrite_saved;

wire [2:0] final_rd_ex =
    mul_done_ex ? mul_rd_saved :
    div_done_ex ? div_rd_saved :
    rd_ex;
    
wire [15:0] final_ex_result =
    is_clear ? 16'd0 :
    is_move  ? opA   :
    is_loadi ? imm_ex :
    alu_result;
    
always @(posedge clk) begin
    $display(
    "EXRESULTDBG: mul_done=%b div_done=%b alu_result=%0d final_ex_result=%0d",
    mul_done_ex,
    div_done_ex,
    alu_result,
    final_ex_result
    );
end
always @(posedge clk) begin
    if(div_done_ex)
    $display(
    "CPU_DIV_DONE: result=%0d rd=%0d",
    final_ex_result,
    final_rd_ex
    );
end   
 
always @(posedge clk) begin
    $display(
    "MULRESULTDBG: mul_done=%b div_done=%b alu_result=%0d final_ex_result=%0d",
    mul_done_ex,
    div_done_ex,
    alu_result,
    final_ex_result
    );
end

always @(posedge clk or posedge reset) begin
    if(reset) begin
        mul_rd_saved <= 3'b000;
        div_rd_saved <= 3'b000;

        mul_regwrite_saved <= 1'b0;
        div_regwrite_saved <= 1'b0;
    end
    else begin

        if(mul_start_capture) begin
            mul_rd_saved <= rd_ex;
            mul_regwrite_saved <= reg_write_ex;
        end

        if(div_start_capture) begin
            div_rd_saved       <= rd_ex;
            div_regwrite_saved <= reg_write_ex;
        end

    end
end

wire final_reg_write_ex =
    mul_done_ex ? mul_regwrite_saved :
    div_done_ex ? div_regwrite_saved :
    reg_write_ex;

always @(posedge clk) begin
    $display(
    "RDCAP: stall=%b stall_d=%b rd_ex=%0d mul_saved=%0d div_saved=%0d mul_done=%b div_done=%b final_rd=%0d",
    alu_stall,
    alu_stall_d,
    rd_ex,
    mul_rd_saved,
    div_rd_saved,
    mul_done_ex,
    div_done_ex,
    final_rd_ex
    );
end

always @(posedge clk) begin
    $display(
    "REGWRDBG: reg_write_ex=%b reg_write_mem=%b reg_write_wb=%b mul_done=%b div_done=%b",
    reg_write_ex,
    reg_write_mem,
    reg_write_wb,
    mul_done_ex,
    div_done_ex
    );
end

always @(posedge clk) begin
    if(reg_write_wb)
        $display(
        "FINALWRITE: R%0d <= %0d",
        rd_wb,
        writeback_data
        );
end

always @(posedge clk) begin
    $display(
    "RDTRACE: rd_ex=%b mul_saved=%b div_saved=%b final_rd=%b",
    rd_ex, mul_rd_saved, div_rd_saved, final_rd_ex);
end

//------------------------------------------------------------
// EX/MEM REGISTER
//------------------------------------------------------------
wire        is_push_mem, is_pop_mem, is_peak_mem;
wire [15:0] rs2_mem;
wire        mem_read_mem, mem_write_mem, mem_to_reg_mem;
wire        branch_taken_mem;
wire [7:0]  branch_addr_mem;
wire        halt_mem;
// Declare:
wire [15:0] push_data_mem;
// Connect from ex_mem_reg: .push_data_out(push_data_mem)
// ===================================================================
// FIXED PIPELINED EX/MEM BINDING LAYER INSIDE cpu_top
// ===================================================================
ex_mem_reg EX_MEM (
    .clk(clk),
    .reset(reset),
    .alu_stall(alu_stall),    // ← ADD THIS
    .mul_done_in(mul_done_ex),
    .div_done_in(div_done_ex),
    .push_data_out(push_data_mem),

    .result_in(final_ex_result),
    .rd_in(final_rd_ex),
    
    // [F4] Pass forwarded store data (opB_raw), not the raw unforwarded rs2_ex register wire
    .rs2_fwd_in(opB_raw), 
    
    // FIXED CORRECTION: Sourced from forwarded opA, not the unforwarded raw rs1_ex wire line!
    // This guarantees the memory module receives the valid, forwarded runtime data during stalls.
    .push_data_in(opA),   
    
    .reg_write_in(final_reg_write_ex),
    .mem_read_in(mem_read_ex),
    .mem_write_in(mem_write_ex),
    .mem_to_reg_in(mem_to_reg_ex),
    .branch_taken_in(branch_taken),
    .branch_addr_in(branch_addr),
    .halt_in(halt_ex),
    .is_push_in(is_push_ex),
    .is_pop_in(is_pop_ex),
    .is_peak_in(is_peak_ex),

    .halt_out(halt_mem),
    .result_out(result_mem),
    .rd_out(rd_mem),
    .rs2_out(rs2_mem),
    .reg_write_out(reg_write_mem),
    .mem_read_out(mem_read_mem),
    .mem_write_out(mem_write_mem),
    .mem_to_reg_out(mem_to_reg_mem),
    .is_push_out(is_push_mem),
    .is_pop_out(is_pop_mem),
    .is_peak_out(is_peak_mem)
);

//============================================================
// STAGE 4 : MEM
//============================================================

// Stack pointer - updates on posedge after MEM uses current sp
wire [7:0] sp;
stack_pointer SP (
    .clk(clk),.reset(reset),
    .push(is_push_mem),.pop(is_pop_mem),.sp(sp), .alu_stall(alu_stall)
);

// [F3] Combinational memory address - no 1-cycle delay
// [F8] PUSH uses current sp (pre-decrement); POP uses sp (pre-increment = the
//      slot that was last pushed). Stack grows downward (sp decrements on push).
//      Correct semantics:
//        PUSH: write to sp, then sp-=1  → address = sp (current, before update)
//        POP : sp+=1, then read from sp → address = sp+1 (current+1 = last pushed)
//        PEAK: read from sp+1 (top of stack without popping)
wire [7:0] mem_addr_w =
    is_push_mem ? sp         :   // [F8] write to current sp, then sp decrements
    is_pop_mem  ? (sp + 1)   :   // [F8] sp will increment; read from sp+1 (top)
    is_peak_mem ? (sp + 1)   :   // [F8] peek top without popping
    result_mem[7:0];              // Normal load/store: ALU result is the address

data_memory DMEM (
    .clk(clk),.reset(reset),
    .mem_read(mem_read_mem),.mem_write(mem_write_mem),
    .addr(mem_addr_w),            // [F3] combinational, not registered
    .write_data(is_push_mem ? push_data_mem : rs2_mem),
    .read_data(debug_mem_data)
);

wire [15:0] mem_data = debug_mem_data;

// MEM/WB register
wire [15:0] mem_data_wb, alu_result_wb;
wire        mem_to_reg_wb;

wire [15:0] mem_data_wb_out;          // ADD this wire declaration before MEM_WB

mem_wb_reg MEM_WB (
    .clk(clk), .reset(reset),
    .mem_data_in(mem_data),           // ← FIXED: pass DMEM read data into the register
    .alu_result_in(result_mem),
    .rd_in(rd_mem), .reg_write_in(reg_write_mem),
    .alu_stall(alu_stall),
    .mul_done_in(mul_done_ex),
    .div_done_in(div_done_ex),
    .mem_to_reg_in(mem_to_reg_mem), .halt_in(halt_mem),
    .halt_out(halt_wb),
    .mem_data_out(mem_data_wb_out),   // ← FIXED: capture the registered output
    .alu_result_out(alu_result_wb), .rd_out(rd_wb),
    .reg_write_out(reg_write_wb), .mem_to_reg_out(mem_to_reg_wb)
);

always @(posedge clk) begin
    $display(
    "WBPATH: rd_mem=%0d result_mem=%0d regwrite_mem=%b | rd_wb=%0d alu_wb=%0d regwrite_wb=%b",
    rd_mem,
    result_mem,
    reg_write_mem,
    rd_wb,
    alu_result_wb,
    reg_write_wb
    );
end

//============================================================
// STAGE 5 : WB
//============================================================
writeback_mux WB (
    .alu_result(alu_result_wb),
    .mem_data(mem_data_wb_out),       // ← FIXED: use registered MEM/WB output
    .mem_to_reg(mem_to_reg_wb),
    .write_data(writeback_data)
);

always @(posedge clk) begin
    $display("WBMUX: mem_to_reg_wb=%b mem_data=%0d alu_result_wb=%0d wb_data=%0d",
    mem_to_reg_wb, mem_data_wb_out, alu_result_wb, writeback_data);
end

always @(posedge clk) begin
    $display(
    "WBDBG: rd_wb=%0d reg_write_wb=%b wb_data=%0d",
    rd_wb,
    reg_write_wb,
    writeback_data
    );
end

// Debug outputs
assign debug_result    = writeback_data;
assign debug_rd        = rd_wb;
assign debug_reg_write = reg_write_wb;
assign flags_out_debug = flags_out;
assign debug_sp        = sp;

// [F9] Debug displays moved to clocked blocks (no more delta-cycle spam)
always @(posedge clk) begin
    if (debug_reg_write)
        $display("[WB] RD=R%0d DATA=%0d (0x%h)", rd_wb, writeback_data, writeback_data);
end

always @(posedge clk) begin
    $display("[FWD] rs1=%0d rs2=%0d rdM=%0d rdW=%0d FA=%b FB=%b",
        rs1_addr_ex, rs2_addr_ex, rd_mem, rd_wb, forwardA, forwardB);
end

assign debug_alu_result_ex = alu_result;
assign debug_rs1_ex        = rs1_ex;
assign debug_rs2_ex        = rs2_ex;

endmodule
